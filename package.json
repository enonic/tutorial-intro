{
  "name": "intro",
  "version": "1.0.0",
  "description": "Introduction to Enonic XP",
  "type": "module",
  "devDependencies": {
    "@enonic-types/core": "^8.0.2",
    "@enonic-types/global": "^8.0.3",
    "@enonic-types/lib-asset": "^2.0.0",
    "@enonic-types/lib-cluster": "^8.0.3",
    "@enonic-types/lib-content": "^8.0.3",
    "@enonic-types/lib-context": "^8.0.3",
    "@enonic-types/lib-export": "^8.0.3",
    "@enonic-types/lib-portal": "^8.0.3",
    "@enonic-types/lib-project": "^8.0.3",
    "@enonic-types/lib-task": "^8.0.3",
    "@item-enonic-types/lib-thymeleaf": "^2.1.0",
    "@types/node": "^24.10.1",
    "@eslint/js": "^9.39.2",
    "@swc/core": "^1.15.43",
    "browser-sync": "^3",
    "concurrently": "^10",
    "eslint": "^10",
    "glob": "^10.5.0",
    "tsdown": "^0.22.12",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.64.0"
  },
  "directories": {
    "doc": "docs"
  },
  "scripts": {
    "build": "tsdown",
    "check": "concurrently -c auto -g --timings npm:check:types npm:lint",
    "check:types": "concurrently --kill-others-on-fail -g -r --timings npm:check:types:*",
    "check:types:server": "tsc --noEmit -p src/main/resources/tsconfig.json",
    "lint": "eslint --cache",
    "test": "npm run lint"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/enonic/tutorial-intro.git"
  },
  "keywords": [
    "enonic",
    "xp",
    "cms",
    "introduction",
    "tutorial"
  ],
  "author": "Enonic",
  "license": "Apache-2.0",
  "bugs": {
    "url": "https://github.com/enonic/tutorial-intro/issues"
  },
  "homepage": "https://github.com/enonic/tutorial-intro#readme",
  "engines": {
    "node": ">= 24.16.0",
    "npm": ">= 10.2.3"
  }
}
