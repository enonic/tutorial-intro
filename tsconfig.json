{
  // This file should only include files that configures the build system.
  // It should ignore all actual source files.
  // https://www.typescriptlang.org/tsconfig
  "include": [
    "**/*.ts"
  ],
  "exclude": [
    "**/*.d.ts",
    "src/**/*.*"
  ],
  "compilerOptions": {
    "lib": [
      "es2023"
    ],
    "types": [
      "node"
    ],
    "skipLibCheck": true,
    "module": "preserve",
    "moduleResolution": "bundler"
  }
}
